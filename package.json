{
  "name": "st-benedicts-media-cloud",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:sync": "npm run build && cap sync",
    "android:open": "npm run mobile:sync && cap open android",
    "android:build": "npm run mobile:sync && cd android && gradlew assembleDebug",
    "ios:open": "npm run mobile:sync && cap open ios",
    "ios:prep": "npm install --legacy-peer-deps && npm run build && npx cap sync ios && cd ios/App && pod install"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@headlessui/react": "^2.2.9",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.24",
    "html5-qrcode": "^2.3.8",
    "mongodb": "^7.2.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}
